    "ws": "^8.14.2",
    "dotenv": "^16.3.1",
    "pino": "^8.16.1",
    "pino-pretty": "^10.2.3",
    "@types/express": "^4.17.20",
    "@types/node": "^20.9.0",
    "@types/ws": "^8.5.8",
    "typescript": "^5.2.2"
  },
  "devDependencies": {
    "ts-node-dev": "^2.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
