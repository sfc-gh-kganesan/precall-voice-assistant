{
  "name": "twilio-openai-pre-call-app",
  "version": "1.0.0",
  "description": "Twilio voice webhook server with OpenAI Realtime API for pharmaceutical sales rep pre-call preparation",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "lint": "eslint src --ext .ts",
    "clean": "rm -rf dist"
