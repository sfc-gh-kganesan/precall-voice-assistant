USE SCHEMA KNOWLEDGE_BUILDER.PUBLIC;

CREATE STAGE IF NOT EXISTS TAXONOMY_APP
  DIRECTORY = (ENABLE = TRUE);

ALTER STAGE TAXONOMY_APP REFRESH;

PUT file://../../apps/taxonomy_app/*.py @taxonomy_app/taxonomy_app/ 
  OVERWRITE=true
  AUTO_COMPRESS = FALSE;

PUT file://../../apps/taxonomy_app/environment.yml @taxonomy_app/taxonomy_app/
  OVERWRITE=true
  AUTO_COMPRESS = FALSE;

PUT file://../../apps/taxonomy_app/styles.css @taxonomy_app/taxonomy_app/
  OVERWRITE=true
  AUTO_COMPRESS = FALSE;

LS @TAXONOMY_APP;

CREATE OR REPLACE STREAMLIT TAXONOMY_APP
  FROM '@TAXONOMY_APP/taxonomy_app/'
  MAIN_FILE = 'streamlit_app.py'
  QUERY_WAREHOUSE = COMPUTE_WH
  TITLE = 'Taxonomy Review';

ALTER STREAMLIT TAXONOMY_APP ADD LIVE VERSION FROM LAST;
