-- ==============================================================================
-- Base64 Image Extractor (Stored Procedure)
--
-- Purpose:
--   Scan KB article HTML for <img src="data:image/...;base64,..."> images and
--   upload the decoded bytes into a Snowflake stage.
--
-- Idempotency:
--   Uses DIRECTORY(@stage) as the state store. Images are written to a deterministic
--   path: BASE64/<sha256>.<ext>. If the path already exists, the upload is skipped.
-- ============================================================================== 

CREATE OR REPLACE PROCEDURE {{ KB_DATABASE_NAME }}.{{ KB_SCHEMA_NAME }}.KB_EXTRACT_BASE64_IMAGES_TO_STAGE(
    kb_table STRING,          -- fully qualified, e.g. 'DB.SCHEMA.KB_KNOWLEDGE'
    kb_id_col STRING,         -- e.g. 'SYS_ID'
    kb_text_col STRING,       -- e.g. 'TEXT'
    target_stage STRING,      -- fully qualified stage name WITHOUT leading '@'
    max_images INT,           -- max images to upload per run
    max_size_bytes INT        -- max decoded image size to upload
)
RETURNS VARIANT
LANGUAGE PYTHON
RUNTIME_VERSION = '3.10'
PACKAGES = ('snowflake-snowpark-python', 'bs4')
HANDLER = 'run'
EXECUTE AS OWNER
AS
$$
import base64
import hashlib
import io
import logging
from datetime import datetime
from typing import Optional, Tuple

from bs4 import BeautifulSoup
from snowflake.snowpark import Session

logger = logging.getLogger("KB_EXTRACT_BASE64_IMAGES")


def _ensure_stage(session: Session, stage_name: str) -> None:
    session.sql(f"""
        CREATE STAGE IF NOT EXISTS {stage_name}
        DIRECTORY = (ENABLE = TRUE)
        ENCRYPTION = (TYPE = 'SNOWFLAKE_SSE')
        COMMENT = 'Stage for base64 images extracted from KB HTML'
    """).collect()


def _refresh_directory(session: Session, stage_name: str) -> None:
    session.sql(f"ALTER STAGE {stage_name} REFRESH").collect()


def _file_ext_from_mime(mime_subtype: str) -> str:
    if not mime_subtype:
        return "bin"
    mt = mime_subtype.lower().strip()
    # common aliases
    if mt in ("jpeg", "pjpeg"):
        return "jpg"
    if mt == "svg+xml":
        return "svg"
    # keep simple, avoid path chars
    return "".join(ch for ch in mt if ch.isalnum() or ch in ("+", "-", "."))[:16] or "bin"


def _decode_data_uri(src: str) -> Optional[Tuple[str, bytes]]:
    """Return (ext, bytes) if src is an image data URI, else None."""
    if not src:
        return None
    if not src.startswith("data:image/"):
        return None
    try:
        # format: data:image/<subtype>;base64,<data>
        header, b64data = src.split(",", 1)
        # e.g. "data:image/png;base64"
        mime_part = header.split(";")[0]  # "data:image/png"
        subtype = mime_part.split("/")[1] if "/" in mime_part else ""
        ext = _file_ext_from_mime(subtype)
        raw = base64.b64decode(b64data)
        return (ext, raw)
    except Exception:
        return None


def _is_already_exists_error(exc: Exception) -> bool:
    msg = str(exc).lower()
    return ("already exists" in msg) or ("file with same name already exists" in msg)


def run(session: Session,
        kb_table: str,
        kb_id_col: str,
        kb_text_col: str,
        target_stage: str,
        max_images: int,
        max_size_bytes: int):

    started_at = datetime.utcnow().strftime("%Y-%m-%d %H:%M:%S")

    _ensure_stage(session, target_stage)
    _refresh_directory(session, target_stage)

    # Existing hashes in stage (prefix BASE64/)
    existing_sql = f"""
        SELECT SPLIT_PART(RELATIVE_PATH, '.', 1) AS HASH
        FROM DIRECTORY(@{target_stage})
        WHERE RELATIVE_PATH LIKE 'BASE64/%'
    """
    existing_hashes = {r["HASH"].replace("BASE64/", "") for r in session.sql(existing_sql).to_local_iterator()}

    logger.info("EXTRACT_START", extra={
        "started_at_utc": started_at,
        "kb_table": kb_table,
        "target_stage": target_stage,
        "max_images": max_images,
        "max_size_bytes": max_size_bytes,
        "existing_hashes_count": len(existing_hashes),
    })

    # Fetch HTML rows
    rows = session.sql(f"SELECT {kb_id_col} AS ID, {kb_text_col} AS TEXT FROM {kb_table}").to_local_iterator()

    uploaded = 0
    skipped = 0
    too_large = 0
    errors = 0

    for row in rows:
        if uploaded >= max_images:
            break
        html = row["TEXT"]
        if not html:
            continue
        soup = BeautifulSoup(html, "html.parser")
        for img in soup.find_all("img"):
            if uploaded >= max_images:
                break
            src = img.get("src", "")
            decoded = _decode_data_uri(src)
            if not decoded:
                continue
            ext, raw = decoded
            if len(raw) > max_size_bytes:
                too_large += 1
                continue
            h = hashlib.sha256(raw).hexdigest()
            if h in existing_hashes:
                skipped += 1
                continue
            stage_path = f"@{target_stage}/BASE64/{h}.{ext}"
            try:
                session.file.put_stream(
                    input_stream=io.BytesIO(raw),
                    stage_location=stage_path,
                    auto_compress=False,
                    overwrite=False,
                )
                uploaded += 1
                existing_hashes.add(h)
            except Exception as e:
                if _is_already_exists_error(e):
                    skipped += 1
                    existing_hashes.add(h)
                else:
                    errors += 1
                    logger.warning("EXTRACT_PUT_FAILED", extra={"hash": h, "error": str(e)[:500]})

    result = {
        "status": "SUCCESS" if errors == 0 else "PARTIAL_SUCCESS",
        "uploaded": uploaded,
        "skipped": skipped,
        "too_large": too_large,
        "errors": errors,
    }
    logger.info("EXTRACT_COMPLETE", extra=result)
    return result
