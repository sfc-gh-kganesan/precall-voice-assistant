INSERT OVERWRITE INTO {{ KB_DATABASE_NAME }}.{{ KB_SCHEMA_NAME }}.KB_CHUNKS
WITH CLEANED AS (
    SELECT
        NUMBER AS KB_SYS_ID,
        SHORT_DESCRIPTION,
        KB_KNOWLEDGE_BASE AS KNOWLEDGE_BASE,
        CAN_READ_USER_CRITERIA,
        CANNOT_READ_USER_CRITERIA,
        SYS_UPDATED_ON AS SOURCE_UPDATED_ON,
        TRIM(REGEXP_REPLACE(REGEXP_REPLACE(TEXT, '<[^>]+>|&nbsp;', ' '), '\\s+', ' ')) AS CLEAN_TEXT
    FROM {{ KB_DATABASE_NAME }}.{{ KB_SCHEMA_NAME }}.KB_KNOWLEDGE
    WHERE TEXT IS NOT NULL
),

CHUNKED AS (
    SELECT
        KB_SYS_ID,
        SHORT_DESCRIPTION,
        KNOWLEDGE_BASE,
        CAN_READ_USER_CRITERIA,
        CANNOT_READ_USER_CRITERIA,
        SOURCE_UPDATED_ON,
        SNOWFLAKE.CORTEX.SPLIT_TEXT_RECURSIVE_CHARACTER(
            CLEAN_TEXT,
            'none',
            1800,
            300
        ) AS CHUNKS
    FROM CLEANED
)

SELECT
    C.KB_SYS_ID,
    C.KB_SYS_ID AS KB_NUMBER,
    ROW_NUMBER() OVER (PARTITION BY C.KB_SYS_ID ORDER BY F.INDEX) AS CHUNK_INDEX,
    F.VALUE::STRING AS CHUNK_TEXT,
    C.SHORT_DESCRIPTION,
    C.KNOWLEDGE_BASE,
    C.CAN_READ_USER_CRITERIA,
    C.CANNOT_READ_USER_CRITERIA,
    'v1' AS PROCESSING_VERSION,
    C.SOURCE_UPDATED_ON,
    CURRENT_TIMESTAMP() AS CREATED_AT
FROM CHUNKED AS C,
LATERAL FLATTEN(input => C.CHUNKS) AS F;
