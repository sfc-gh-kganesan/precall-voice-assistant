# Clean Docker images and cache
clean:
    #!/usr/bin/env bash
    set -euo pipefail
    echo "🧹 Cleaning up..."
    cargo clean 2>/dev/null || true
    docker images | grep -E 'kb-builder-svc|example-job' | awk '{print $3}' | xargs docker rmi -f 2>/dev/null || true
    find . -type d -name '__pycache__' -exec rm -rf {} + 2>/dev/null || true
    find . -type f -name '*.pyc' -delete 2>/dev/null || true
    rm -f release/*.tmp 2>/dev/null || true
    echo "✅ Cleanup complete"
