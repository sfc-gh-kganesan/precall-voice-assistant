# Load environment variables from .env
set dotenv-load := true

# Export all variables
set export := true

# Default recipe (run `just` with no args)
default: help

# Show this help message
help:
    @echo "Knowledge Builder Service"
    @echo ""
    @just --list --unsorted
    @echo ""

# Setup development environment
install:
    uv sync

# Download and setup NLTK tokenizers for Streamlit deployment
setup-nltk:
    #!/usr/bin/env bash
    set -euo pipefail
    echo "📦 Downloading NLTK tokenizer data..."

    # Create temp dir and download there
    TEMP_DIR=$(mktemp -d)
    uv run python -c "import nltk; nltk.download('punkt', download_dir='$TEMP_DIR'); nltk.download('punkt_tab', download_dir='$TEMP_DIR')"

    echo "📂 Setting up nltk_data/tokenizers directory..."
    rm -rf nltk_data
    mkdir -p nltk_data/tokenizers

    # Copy zip files to current directory
    cp "$TEMP_DIR/tokenizers/punkt.zip" .
    cp "$TEMP_DIR/tokenizers/punkt_tab.zip" .

    echo "📦 Extracting punkt.zip..."
    unzip -q -o punkt.zip -d nltk_data/tokenizers

    echo "📦 Extracting punkt_tab.zip..."
    unzip -q -o punkt_tab.zip -d nltk_data/tokenizers

    # Cleanup temp dir
    rm -rf "$TEMP_DIR"

    echo "✅ NLTK setup complete. nltk_data/ ready for deployment."

# Start dev server with auto-reload (optionally specify port, default: 8000)
kb_builder_svc port="8000": install
    uv run uvicorn --app-dir=./src/services kb_builder_svc:app --host 0.0.0.0 --port {{port}} --reload

# Private: Get connection flag for snow CLI
_connection-flag:
    #!/usr/bin/env bash
    if [ "$SNOW_CONNECTION" != "default" ]; then
        echo "--connection $SNOW_CONNECTION"
    fi

# Run schemachange migrations
migrate:
    #!/usr/bin/env bash
    set -euo pipefail
    echo "🗄️  Running database migrations with schemachange..."
    uv run schemachange deploy -C "$SNOW_CONNECTION"

deploy:
    #!/usr/bin/env bash
    set -euo pipefail
    CONNECTION_FLAG=$(just _connection-flag)

    # Login to registry
    echo "🔐 Logging into Snowflake image registry..."
    snow spcs image-registry login --role $ROLE_NAME $CONNECTION_FLAG --silent || echo "⚠️  Registry login failed or already logged in"

    # Run database migrations with schemachange
    echo "🗄️  Running database migrations..."
    just migrate

    # Build and push Docker image
    echo "🐳 Building Docker image..."
    SPCS_REPO_URL=$(snow spcs image-repository url $SPCS_IMAGE_REPO_NAME $CONNECTION_FLAG --database $SPCS_DATABASE_NAME --schema $SPCS_SCHEMA_NAME --role $ROLE_NAME --silent)
    echo "Building image..."
    cd docker && docker build --rm --platform linux/amd64 -t $SPCS_REPO_URL/$KB_BUILDER_IMAGE_NAME:latest -f Dockerfile.kb_builder_svc ../. --quiet
    cd ..
    echo "📤 Pushing to Snowflake image repository..."
    docker push $SPCS_REPO_URL/kb-builder-svc:latest --quiet

    # Deploy Streamlit app
    echo "🎨 Deploying Streamlit app..."
    snow streamlit deploy $CONNECTION_FLAG --replace

    echo ""
    echo "✅ 🎉 Deployment complete!"


# Check service status
kb_builder_svc_status:
    #!/usr/bin/env bash
    set -euo pipefail
    echo "📊 Checking service status..."
    CONNECTION_FLAG=$(just _connection-flag)
    snow spcs service status $KB_BUILDER_SVC_NAME $CONNECTION_FLAG --database $SPCS_DATABASE_NAME --schema $SPCS_SCHEMA_NAME --role $ROLE_NAME

# View service logs (optionally specify instance-id, default: 0)
kb_builder_svc_logs instance="0":
    #!/usr/bin/env bash
    set -euo pipefail
    echo "📋 Fetching service logs (instance {{instance}})..."
    CONNECTION_FLAG=$(just _connection-flag)
    snow spcs service logs $KB_BUILDER_SVC_NAME $CONNECTION_FLAG --database $SPCS_DATABASE_NAME --schema $SPCS_SCHEMA_NAME --role $ROLE_NAME --container-name kb-builder-container --instance-id {{instance}}

# Show public endpoint URL
kb_builder_svc_url:
    #!/usr/bin/env bash
    set -euo pipefail
    CONNECTION_FLAG=$(just _connection-flag)
    snow spcs service list-endpoints $KB_BUILDER_SVC_NAME $CONNECTION_FLAG --database $SPCS_DATABASE_NAME --schema $SPCS_SCHEMA_NAME --role $ROLE_NAME --format JSON_EXT

# Check code quality (used by CI)
check:
    @echo "🔍 Checking import sorting..."
    uv run ruff check --select I
    @echo "🔍 Checking linting..."
    uv run ruff check
    @echo "🔍 Checking formatting..."
    uv run ruff format --check
    @echo "🔍 Checking SQL..."
    uv run sqlfluff lint schemachange/
    @echo "✅ All checks passed"

# Format and lint code (auto-fix)
fmt:
    uv run ruff check --select I --fix .
    uv run ruff format .
    uv run ruff check --fix .
    uv run sqlfluff fix schemachange/
    @echo "✅ Code formatted and linted"

alias format := fmt

