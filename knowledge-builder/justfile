# View example job logs (optionally specify instance-id, default: 0)
example_job_logs instance="0":
    #!/usr/bin/env bash
    set -euo pipefail
    echo "📋 Fetching example job logs (instance {{instance}})..."
    CONNECTION_FLAG=$(just _connection-flag)
