{
    "name": "@p67/web",
    "private": true,
    "version": "1.0.0",
    "type": "module",
    "scripts": {
        "dev": "vite",
        "build": "tsc -b && vite build",
        "preview": "vite preview",
        "check": "pnpm exec biome check --error-on-warnings",
        "fix": "pnpm exec biome check --write",
        "type:check": "tsc --noEmit",
        "ci": "run-p check type:check build"
    },
    "dependencies": {
        "@mantine/core": "^8.3.7",
        "@mantine/hooks": "^8.3.7",
        "react": "^19.2.0",
        "react-dom": "^19.2.0"
    },
    "devDependencies": {
        "@types/node": "^24.10.0",
        "@types/react": "^19.2.2",
        "@types/react-dom": "^19.2.2",
        "@vitejs/plugin-react": "^5.1.0",
        "postcss": "^8.5.6",
        "postcss-preset-mantine": "^1.18.0",
        "postcss-simple-vars": "^7.0.1",
        "vite": "^7.2.2",
        "vitest": "^4.0.9"
    }
}
