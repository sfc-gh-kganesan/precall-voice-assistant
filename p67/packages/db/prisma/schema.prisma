// This is your Prisma schema file

generator client {
  provider                  = "prisma-client"
  output                    = "../src/generated/prisma"
  runtime                   = "nodejs"
  moduleFormat              = "esm"
  generatedFileExtension    = "ts"
  importFileExtension       = "js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String   @id @default(uuid())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  snowflakeUser String   @unique
  workflows Workflow[]
  secrets Secret[]
  workflowRuns WorkflowRun[]
}

enum WorkflowVisibility {
    Private
    Public
}

model Workflow {
    id String @id @default(uuid())
    storagePath String // the directory on disk (block storage volume) where workflow artifacts are stored
    ownerId String
    owner User @relation(fields: [ownerId], references: [id])
    createdAt DateTime @default(now())
    updatedAt DateTime @default(now())
    visibility WorkflowVisibility @default(Private)
    runs WorkflowRun[]
}

enum LogSource {
    RuntimeHost      // Logs from the runtime host process
    WorkflowNode     // Logs from workflow node execution
    ToolCall         // Logs from tool/function calls
}

model WorkflowRun {
    id          String    @id @default(uuid())
    workflowId  String
    workflow    Workflow  @relation(fields: [workflowId], references: [id], onDelete: Cascade)
    userId      String
    user        User      @relation(fields: [userId], references: [id])
    startedAt   DateTime  @default(now())
    completedAt DateTime?
    exitCode    Int?
    logs        Log[]

    @@index([workflowId])
    @@index([userId])
}

model Log {
    id          String    @id @default(uuid())
    runId       String
    run         WorkflowRun @relation(fields: [runId], references: [id], onDelete: Cascade)
    workflowId  String    // Denormalized for efficient querying
    userId      String    // Denormalized for RBAC filtering
    source      LogSource
    message     String
    attributes  Json      @default("{}")  // Custom key-value attributes
    timestamp   DateTime  @default(now())

    @@index([runId])
    @@index([workflowId])
    @@index([userId])
    @@index([timestamp])
}

model Secret {
  id        String   @id @default(uuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ownerId   String
  owner     User     @relation(fields: [ownerId], references: [id])
  secret    String
  // tags
  // TODO: sharing

  @@unique([ownerId, name])
}