import { Annotation, StateGraph } from '@langchain/langgraph';
import type { WorkflowSDK } from './sdk';

/**
 * Hello World workflow — a LangGraph pipeline that demonstrates core P67 SDK
 * features inside graph nodes:
 *
 *   1. Initialize  – reads a user-supplied parameter via sdk.getParameter()
 *   2. Generate    – calls Snowflake Cortex AI via sdk.cortexComplete()
 *   3. Finalize    – assembles and returns the result
 *
 * Prerequisites: add your Snowflake connection credentials to manifest.yaml
 * so that cortexComplete() can authenticate. See the config block there.
 */

// ── State ──────────────────────────────────────────────────────────
const StateAnnotation = Annotation.Root({
    topic: Annotation<string>({
        reducer: (_, right) => right,
    }),
    summary: Annotation<string>({
        reducer: (_, right) => right,
    }),
    sdk: Annotation<WorkflowSDK>({
        reducer: (_, right) => right,
    }),
});

// ── Node 1: Initialize ────────────────────────────────────────────
async function initialize(state: typeof StateAnnotation.State) {
    const topic = state.sdk.getParameter('topic') ?? 'Snowflake data warehousing';
    console.log(`[initialize] topic="${topic}"`);
    return { topic };
}

// ── Node 2: Generate ──────────────────────────────────────────────
async function generate(state: typeof StateAnnotation.State) {
    console.log('[generate] Calling Cortex AI...');
    const response = await state.sdk.cortexComplete({
        model: 'llama3.1-8b',
        messages: `Write a short, friendly two-sentence summary about: ${state.topic}`,
        maxTokens: 200,
    });

    const content = response.choices?.[0]?.message?.content ?? '';
    console.log(`[generate] Response: ${content.slice(0, 120)}...`);
    return { summary: content };
}

// ── Node 3: Finalize ──────────────────────────────────────────────
async function finalize(state: typeof StateAnnotation.State) {
    console.log('[finalize] Assembling result');
    return { summary: state.summary };
}

// ── Graph ──────────────────────────────────────────────────────────
const workflow = new StateGraph(StateAnnotation)
    .addNode('initialize', initialize)
    .addNode('generate', generate)
    .addNode('finalize', finalize)
    .addEdge('__start__', 'initialize')
    .addEdge('initialize', 'generate')
    .addEdge('generate', 'finalize')
    .addEdge('finalize', '__end__');

const app = workflow.compile();

// ── Entry point ────────────────────────────────────────────────────
export async function main(sdk: WorkflowSDK) {
    console.log('Starting hello_world workflow...\n');

    const result = await app.invoke({
        topic: '',
        summary: '',
        sdk,
    });

    console.log('\n=== Result ===');
    console.log(`Topic: ${result.topic}`);
    console.log(`Summary: ${result.summary}`);

    return { topic: result.topic, summary: result.summary };
}
