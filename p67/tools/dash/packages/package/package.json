    "sideEffects": false,
    "main": "./dist/main.es.js",
    "types": "./dist/main.d.ts",
    "exports": {
        ".": {
            "import": "./dist/main.es.js",
            "types": "./dist/main.d.ts",
            "require": "./dist/main.cjs.js",
            "default": "./dist/main.es.js"
        },
        "./types": "./dist/main.d.ts",
        "./getThemesForColorScheme": {
            "import": "./dist/BaltoProvider/getThemesForColorScheme.es.js",
            "types": "./dist/BaltoProvider/getThemesForColorScheme.d.ts",
            "require": "./dist/BaltoProvider/getThemesForColorScheme.cjs.js",
            "default": "./dist/BaltoProvider/getThemesForColorScheme.es.js"
        }
    },
    "files": [
        "dist",
        "lib"
    ],
    "dependencies": {
