        "@react-stately/form": "^3.2.1",
        "@react-stately/list": "^3.13.0",
        "@react-stately/overlays": "^3.6.19",
        "@react-stately/toast": "3.1.2",
        "@rollup/plugin-replace": "6.0.2",
        "@stylexjs/stylex": "0.16.1",
