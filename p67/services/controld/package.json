{
    "name": "@p67/controld",
    "version": "1.0.0",
    "description": "Control plane service",
    "type": "module",
    "main": "dist/index.js",
    "scripts": {
        "dev": "tsx watch src/index.ts",
        "build": "tsc && tsc-alias",
        "start": "node dist/index.js",
        "tst": "vitest",
        "test": "vitest run",
        "check": "pnpm exec biome check --error-on-warnings",
        "fix": "pnpm exec biome check --write",
        "type:check": "tsc --noEmit",
        "ci": "run-p check type:check build"
    },
    "dependencies": {
        "@fastify/cors": "^10.0.1",
        "@fastify/multipart": "^9.3.0",
        "@fastify/swagger": "^9.3.0",
        "@fastify/swagger-ui": "^5.2.3",
        "@p67/workflow-sdk": "workspace:*",
        "@p67/db": "workspace:*",
        "adm-zip": "^0.5.16",
        "dotenv": "^17.2.3",
        "fastify": "^5.2.0",
        "fastify-plugin": "^5.1.0",
        "fastify-type-provider-zod": "^4.0.2",
        "pino-pretty": "^13.1.3",
        "snowflake-sdk": "^2.3.3",
        "vitest": "^4.0.9",
        "yaml": "^2.8.2",
        "zod": "^3.23.8"
    },
    "devDependencies": {
        "@types/adm-zip": "^0.5.7",
        "@types/node": "^24.10.1",
        "tsc-alias": "^1.8.16",
        "tsx": "^4.19.2"
    }
}
