{
  "name": "@p67/controld",
  "version": "1.0.0",
  "description": "Control plane service",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc && tsc-alias",
    "start": "node dist/index.js",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css}\"",
    "type:check": "tsc --noEmit"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.1",
    "@fastify/multipart": "^9.3.0",
    "@fastify/swagger": "^9.3.0",
    "@fastify/swagger-ui": "^5.2.3",
    "@p67/db": "workspace:*",
    "adm-zip": "^0.5.16",
    "dotenv": "^17.2.3",
    "fastify": "^5.2.0",
    "fastify-type-provider-zod": "^4.0.2",
    "pino-pretty": "^13.1.3",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/adm-zip": "^0.5.7",
    "@types/node": "^24.10.1",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "globals": "^15.0.0",
    "prettier": "^3.3.0",
    "tsc-alias": "^1.8.16",
    "tsx": "^4.19.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.0.0"
  }
}
