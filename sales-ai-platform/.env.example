# If DEMO_MODE=true, then synthetic call transcripts are pulled from ai_fde.sales_ai_platform.all_engagement_details_synthetic. 
# If DEMO_MODE=false, real transcripts are pulled from sales.engagement360_pitch.all_engagement_details, which requires viewers be on Designated Insiders List.
DEMO_MODE=false

# IF DEDUP_NEW_USE_CASES=true, then run LLM to check if each potential new use case already exists in the new use cases table. This will add extra cost, but might improve UX
DEDUP_NEW_USE_CASES=true

# the connection SnowSQL will use (from ~/.snowflake/config.toml or ~/.snowflake/connections.toml)
# should be lowercase if using "default"
# the connection must be using a role that has privileges to create resources in the account (database, schema, compute pools, network rules)
SNOW_CONNECTION=default

# Snowflake account context
# Many objects will get created in the Database and Schema specified here, including streams, tasks, tables, and service functions
SNOWFLAKE_ACCOUNT=SFCOGSOPS-SNOWHOUSE_AWS_US_WEST_2
SNOWFLAKE_USER=KMASON
DATABASE=AI_FDE
SCHEMA=SALES_AI_PLATFORM
SNOWFLAKE_WAREHOUSE=AI_FDE_M
STAGE=APP_STAGE
COMPUTE_POOL=AI_FDE_COMPUTE_POOL

# this role will be used to deploy the SPCS service
ROLE=AI_FDE_SALES_COLLAB_RO_RL

# Load testing role
LOAD_TEST_ROLE=AI_FDE_ADMIN_RL

# these roles will be granted usage on the created service functions
USAGE_ROLES=AI_FDE_ADMIN_RL,SALES_AI_PLATFORM_APP_RL,SALES_BASIC_RO

# image details
IMAGE_REPOSITORY=IMAGE_REPOSITORY
IMAGE_NAME=sales-ai-platform
IMAGE_TAG=latest

# service details
SERVICE_NAME=sales_ai_platform_service
CONTAINER_NAME=sales-ai-platform
EXTERNAL_ACCESS_INTEGRATION=ALLOW_ALL_EAI

# load test volume
LOAD_TEST_ROW_COUNT=200

# optional langsmith tracing vars
LANGSMITH_TRACING=
LANGSMITH_ENDPOINT=
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=
LANGSMITH_OTEL_ENABLED=true

# optional persistence path overrides
DBOS_SYSTEM_DATABASE_URL=

# choose which API is used with get_llm (valid values: "openai" | "snowflake"; empty defaults to Snowflake Cortex/"snowflake")
LLM_PROVIDER=

# required OpenAI API key for LangSmith
OPENAI_API_KEY=

# (optional) these are only needed for local dev if exercising ChatOpenAI with Snowflake Cortex
SNOWFLAKE_HOST=SFCOGSOPS-SNOWHOUSE-AWS-US-WEST-2.snowflakecomputing.com
SNOWFLAKE_PAT=<your_snowflake_pat_here>

# email necessary for fetch Sales AI MetaOrchestrator auth tokens
METAORCHESTRATOR_AUTH_EMAIL=john.doe@snowflake.com

# (optional) these environment variables turn on local langgraph tracing
LANGGRAPH_TRACING_DIR=local_traces
ENABLE_GRAPH_UI=true
ENABLE_LOCAL_TRACING=true

# (optional) eval model selection
EVAL_MODEL_SELECTION="openai-gpt-5-chat"
EVAL_RESULTS_TABLE="use_case_summary_eval_results"
EVAL_CORRECTNESS_RESULTS_TABLE="use_case_summary_eval_correctness_results"

# eval dashboard related env vars
DASHBOARD_SERVICE_NAME=sales_ai_platform_service_eval_dashboard
DASHBOARD_IMAGE_NAME=sales-ai-platform-eval-dashboard

# graph version environment variable, update it when modify the graph
GRAPH_VERSION=v1.1.1

