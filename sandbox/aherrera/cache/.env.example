# Snowflake Connection
SNOWFLAKE_ACCOUNT=your-account
SNOWFLAKE_USER=your-user
SNOWFLAKE_PAT=your-personal-access-token

# For SPCS deployments
SNOWFLAKE_HOST=your-account.snowflakecomputing.com

# Snowflake Database/Schema/Warehouse
SNOWFLAKE_DATABASE=YOUR_DATABASE
SNOWFLAKE_SCHEMA=YOUR_SCHEMA
SNOWFLAKE_WAREHOUSE=COMPUTE_WH

# Cache Configuration
CACHE_DATABASE=CACHE
CACHE_SCHEMA=EXPERIMENTS

# OpenTelemetry (for SPCS)
OTEL_EXPORTER_OTLP_TRACES_ENDPOINT=http://localhost:4317
