# Snowflake Configuration for InvoiceIQ Agent App
# Copy this file to .env and fill in your actual values
# Required for non-SPCS

# Required: Snowflake account identifier (e.g., "myaccount" or "myaccount.region")
SNOWFLAKE_ACCOUNT=your_account_identifier

# Required: Snowflake Personal Access Token
SNOWFLAKE_PAT=your_personal_access_token

# Required: Snowflake username (for non-SPCS container mode)
SNOWFLAKE_USER=your_username