# Environment Configuration
ENV=prod

# Service Configuration
SERVICE_NAME=dda-service
LOG_LEVEL=INFO
API_V1_PREFIX=/api/v1

# CORS Configuration
CORS_ORIGINS=*

# Snowflake Connection
SNOWFLAKE_ACCOUNT=account
SNOWFLAKE_USER=user
SNOWFLAKE_PASSWORD=
SNOWFLAKE_WAREHOUSE=
SNOWFLAKE_DATABASE=SUPPORT
SNOWFLAKE_SCHEMA=CXE
SNOWFLAKE_ROLE=SUPPORT_CXE_RO_RL

# Authentication (Simple API Key for MVP)
API_KEY=dev_key_12345

# OAuth2 (Phase 2)
# OKTA_DOMAIN=your_domain.okta.com
# OKTA_CLIENT_ID=your_client_id
# OKTA_CLIENT_SECRET=your_client_secret
# OKTA_REDIRECT_URI=http://localhost:8000/api/v1/auth/callback
# JWT_SECRET_KEY=your_jwt_secret
# JWT_ALGORITHM=HS256
# JWT_EXPIRATION_HOURS=8

# Redis Cache (Phase 2)
# REDIS_URL=redis://localhost:6379/0
# CACHE_TTL_SECONDS=900

# Query Execution
QUERY_TIMEOUT_SECONDS=300
MAX_QUERY_RESULTS=10000

# In-Memory Cache (MVP)
CACHE_ENABLED=true
CACHE_TTL_SECONDS=900
CACHE_MAX_SIZE=1000

# JIRA Integration (Optional)
JIRA_ENABLED=false
JIRA_ACCOUNT=snowflakecomputing
JIRA_USER=your.email@snowflake.com
JIRA_API_TOKEN=your_api_token_here
JIRA_PROJECT=SNOW
JIRA_MAX_RESULTS=50
JIRA_CACHE_TTL_SECONDS=300
