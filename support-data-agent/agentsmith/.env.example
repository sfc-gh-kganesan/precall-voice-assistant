# AgentSim Environment Configuration

# Database Selection
# Set to 'true' to use Snowflake, 'false' for SQLite (default)
USE_SNOWFLAKE=false

# SQLite Database Configuration (when USE_SNOWFLAKE=false)
# Path to SQLite database file
# Default: ./agentsim.db (relative to working directory)
# For Docker: Leave as default or use relative path (working dir is /app)
# For local development: Use absolute path to ensure all scripts connect to same database
# Example: /absolute/path/to/project/agentsim/agentsim.db
DATABASE_PATH=./agentsim.db

# Snowflake Configuration (required when USE_SNOWFLAKE=true)
SNOWFLAKE_ACCOUNT=your_account.region
SNOWFLAKE_USER=your_username
SNOWFLAKE_PASSWORD=your_password
SNOWFLAKE_DATABASE=AGENTSIM_DB
SNOWFLAKE_SCHEMA=PUBLIC
SNOWFLAKE_WAREHOUSE=COMPUTE_WH
SNOWFLAKE_ROLE=ACCOUNTADMIN

# Snowflake Cortex Configuration (for LLM judges)
SNOWFLAKE_CORTEX_API_KEY=your_cortex_api_key
SNOWFLAKE_CORTEX_BASE_URL=https://your-account.snowflakecomputing.com/api/v2/cortex
SNOWFLAKE_CORTEX_MODEL=snowflake-arctic

# GitHub Configuration (for Code Agent)
# Get a Personal Access Token from: https://github.com/settings/tokens
# Required scopes: repo (full control of private repositories)
GITHUB_TOKEN=ghp_your_github_personal_access_token
GITHUB_TOOLSETS=context,repos,issues,pull_requests
