FROM python:3.11-slim

LABEL maintainer="Customer Experience Engineering <cxe-team@snowflake.com>"
LABEL description="Snowflake Trace Writer - OTLP to Snowflake Bridge"

WORKDIR /app

# Install system dependencies
RUN apt-get update && apt-get install -y \
    gcc \
    g++ \
    && rm -rf /var/lib/apt/lists/*

# Install uv
COPY --from=ghcr.io/astral-sh/uv:latest /uv /usr/local/bin/uv

# Copy dependency files
COPY pyproject.toml ./

# Install Python dependencies using uv
RUN uv sync

# Copy application code
COPY snowflake_trace_writer.py ./

# Create non-root user for security
RUN useradd -m -u 1000 appuser && \
    chown -R appuser:appuser /app

USER appuser

# Expose port
EXPOSE 8080

# Run with uv
CMD ["uv", "run", "uvicorn", "snowflake_trace_writer:app", "--host", "0.0.0.0", "--port", "8080"]
