# Support Data Agent Backend Service URL
# Local development: http://localhost:8000
# Staging: https://sda-staging.example.com
# Production: https://sda-api.example.com
NEXT_PUBLIC_SDA_SERVICE_URL=http://localhost:8000

# Feature flag to use mock data instead of real backend
# Set to true for frontend-only development without backend
# Set to false to connect to real backend API
NEXT_PUBLIC_USE_MOCK_DATA=false

# Development environment
NEXT_PUBLIC_ENV=development
